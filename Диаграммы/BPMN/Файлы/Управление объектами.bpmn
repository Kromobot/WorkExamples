<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ManageObjects_v1" targetNamespace="http://example.com/bpmn/objects/manage" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_manage_objects" name="Управление объектами" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль «Объекты»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectAction" name="Выбрать действие" />
    <exclusiveGateway id="GX_Action_1" name="Создать?" />
    <userTask id="UT_SelectLayerZone" name="Выбрать слой/зону" />
    <userTask id="UT_SelectTypeCatalog" name="Выбрать тип из каталога" />
    <userTask id="UT_PlaceOnPlan" name="Разместить на плане">
      <outgoing>Flow_1lc4r6q</outgoing>
    </userTask>
    <serviceTask id="ST_SaveCreate" name="Сохранить новый объект">
      <incoming>Flow_1lc4r6q</incoming>
    </serviceTask>
    <exclusiveGateway id="GX_Action_2" name="Редактировать?" />
    <userTask id="UT_SelectObject_Edit" name="Выбрать объект" />
    <userTask id="UT_EditProps" name="Изменить свойства/позицию" />
    <serviceTask id="ST_SaveEdit" name="Сохранить изменения объекта" />
    <exclusiveGateway id="GX_Action_3" name="Удалить?">
      <outgoing>Flow_0fc2gq9</outgoing>
    </exclusiveGateway>
    <userTask id="UT_SelectObject_Del" name="Выбрать объект" />
    <userTask id="UT_ConfirmDelete" name="Подтвердить удаление" />
    <serviceTask id="ST_DoDelete" name="Удалить объект из БД" />
    <serviceTask id="ST_RefreshMap" name="Обновить карту/отображение">
      <incoming>Flow_0fc2gq9</incoming>
    </serviceTask>
    <endEvent id="End_Success" name="Изменения применены" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectAction" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectAction" targetRef="GX_Action_1" />
    <sequenceFlow id="F6_create" name="да" sourceRef="GX_Action_1" targetRef="UT_SelectLayerZone" />
    <sequenceFlow id="F6_else" name="нет" sourceRef="GX_Action_1" targetRef="GX_Action_2" />
    <sequenceFlow id="F7" sourceRef="UT_SelectLayerZone" targetRef="UT_SelectTypeCatalog" />
    <sequenceFlow id="F8" sourceRef="UT_SelectTypeCatalog" targetRef="UT_PlaceOnPlan" />
    <sequenceFlow id="F10" sourceRef="ST_SaveCreate" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F11_edit" name="да" sourceRef="GX_Action_2" targetRef="UT_SelectObject_Edit" />
    <sequenceFlow id="F11_else" name="нет" sourceRef="GX_Action_2" targetRef="GX_Action_3" />
    <sequenceFlow id="F12" sourceRef="UT_SelectObject_Edit" targetRef="UT_EditProps" />
    <sequenceFlow id="F13" sourceRef="UT_EditProps" targetRef="ST_SaveEdit" />
    <sequenceFlow id="F14" sourceRef="ST_SaveEdit" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F15_delete" name="да" sourceRef="GX_Action_3" targetRef="UT_SelectObject_Del" />
    <sequenceFlow id="F16" sourceRef="UT_SelectObject_Del" targetRef="UT_ConfirmDelete" />
    <sequenceFlow id="F17" sourceRef="UT_ConfirmDelete" targetRef="ST_DoDelete" />
    <sequenceFlow id="F18" sourceRef="ST_DoDelete" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F19" sourceRef="ST_RefreshMap" targetRef="End_Success" />
    <sequenceFlow id="Flow_0fc2gq9" name="Нет" sourceRef="GX_Action_3" targetRef="ST_RefreshMap" />
    <sequenceFlow id="Flow_1lc4r6q" sourceRef="UT_PlaceOnPlan" targetRef="ST_SaveCreate" />
  </process>
