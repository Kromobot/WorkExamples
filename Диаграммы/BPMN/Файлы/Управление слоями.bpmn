<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ManageLayers_v1" targetNamespace="http://example.com/bpmn/layers/manage" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_manage_layers" name="Управление слоями" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль «Слои»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectAction" name="Выбрать действие" />
    <exclusiveGateway id="GX_Action_1" name="Создать?">
      <incoming>Flow_1ue0dln</incoming>
      <outgoing>Flow_1xpmcef</outgoing>
    </exclusiveGateway>
    <userTask id="UT_CreateMeta" name="Задать имя/порядок/этаж">
      <outgoing>Flow_1guwqe3</outgoing>
    </userTask>
    <serviceTask id="ST_SaveCreate" name="Сохранить слой">
      <incoming>Flow_1guwqe3</incoming>
    </serviceTask>
    <exclusiveGateway id="GX_Action_2" name="Редактировать?">
      <incoming>F5</incoming>
    </exclusiveGateway>
    <userTask id="UT_SelectLayer_Edit" name="Выбрать слой" />
    <userTask id="UT_EditProps" name="Изменить свойства/заменить изображение" />
    <serviceTask id="ST_SaveEdit" name="Сохранить изменения" />
    <exclusiveGateway id="GX_Action_3" name="Удалить?">
      <outgoing>Flow_1ue0dln</outgoing>
    </exclusiveGateway>
    <userTask id="UT_SelectLayer_Del" name="Выбрать слой" />
    <userTask id="UT_ConfirmDelete" name="Подтвердить удаление" />
    <serviceTask id="ST_DoDelete" name="Удалить слой из БД" />
    <serviceTask id="ST_RefreshMap" name="Обновить карту/отображение">
      <incoming>Flow_1xpmcef</incoming>
    </serviceTask>
    <endEvent id="End_Success" name="Изменения применены" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectAction" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectAction" targetRef="GX_Action_2" />
    <sequenceFlow id="F6_create" name="да" sourceRef="GX_Action_1" targetRef="UT_CreateMeta" />
    <sequenceFlow id="F11" sourceRef="ST_SaveCreate" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F12_edit" name="да" sourceRef="GX_Action_2" targetRef="UT_SelectLayer_Edit" />
    <sequenceFlow id="F12_else" name="Нет" sourceRef="GX_Action_2" targetRef="GX_Action_3" />
    <sequenceFlow id="F13" sourceRef="UT_SelectLayer_Edit" targetRef="UT_EditProps" />
    <sequenceFlow id="F14" sourceRef="UT_EditProps" targetRef="ST_SaveEdit" />
    <sequenceFlow id="F15" sourceRef="ST_SaveEdit" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F16_delete" name="да" sourceRef="GX_Action_3" targetRef="UT_SelectLayer_Del" />
    <sequenceFlow id="F17" sourceRef="UT_SelectLayer_Del" targetRef="UT_ConfirmDelete" />
    <sequenceFlow id="F18" sourceRef="UT_ConfirmDelete" targetRef="ST_DoDelete" />
    <sequenceFlow id="F19" sourceRef="ST_DoDelete" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F20" sourceRef="ST_RefreshMap" targetRef="End_Success" />
    <sequenceFlow id="Flow_1guwqe3" sourceRef="UT_CreateMeta" targetRef="ST_SaveCreate" />
    <sequenceFlow id="Flow_1ue0dln" name="Нет" sourceRef="GX_Action_3" targetRef="GX_Action_1" />
    <sequenceFlow id="Flow_1xpmcef" name="Нет" sourceRef="GX_Action_1" targetRef="ST_RefreshMap" />
  </process>
