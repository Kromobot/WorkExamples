<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_CreateZone_v4_UpDown" targetNamespace="http://example.com/bpmn/zones" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_create_zone_v4" name="Создание зоны (XOR: выходы только вверх/вниз)" isExecutable="false">
    <startEvent id="Start_CreateZone" name="Начало" />
    <userTask id="UT_OpenZones" name="Открыть редактор зон" />
    <userTask id="UT_SelectFloor" name="Выбрать этаж" />
    <userTask id="UT_SelectLayer" name="Выбрать слой" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_ClickCreate" name="Нажать «Создать зону»" />
    <serviceTask id="ST_EnableDrawing" name="Показ инструмента рисования" />
    <userTask id="UT_Draw" name="Нарисовать границу зоны" />
    <serviceTask id="ST_SaveZone" name="Сохранение зоны в БД" />
    <serviceTask id="ST_Render" name="Отображение зоны на плане" />
    <endEvent id="End_Success" name="Зона успешно создана" />
    <sequenceFlow id="F1" sourceRef="Start_CreateZone" targetRef="UT_OpenZones" />
    <sequenceFlow id="F2" sourceRef="UT_OpenZones" targetRef="UT_SelectFloor" />
    <sequenceFlow id="F3" sourceRef="UT_SelectFloor" targetRef="UT_SelectLayer" />
    <sequenceFlow id="F4" sourceRef="UT_SelectLayer" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F5" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F6_yes" name="да" sourceRef="GX_Perms" targetRef="UT_ClickCreate" />
    <sequenceFlow id="F6_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F7" sourceRef="UT_ClickCreate" targetRef="ST_EnableDrawing" />
    <sequenceFlow id="F8" sourceRef="ST_EnableDrawing" targetRef="UT_Draw" />
    <sequenceFlow id="F9" sourceRef="UT_Draw" targetRef="ST_SaveZone" />
    <sequenceFlow id="F10" sourceRef="ST_SaveZone" targetRef="ST_Render" />
    <sequenceFlow id="F11" sourceRef="ST_Render" targetRef="End_Success" />
  </process>
  <bpmndi:BPMNDiagram id="DI_CreateZone_v4">
    <bpmndi:BPMNPlane id="Plane_CreateZone_v4" bpmnElement="process_create_zone_v4">
