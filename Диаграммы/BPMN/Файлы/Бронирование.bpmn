<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_Booking_v1" targetNamespace="http://example.com/bpmn/booking" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_booking" name="Функционал бронирования" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль бронирования" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectResource" name="Выбрать ресурс (переговорка/место)" />
    <userTask id="UT_SelectDateTime" name="Выбрать дату и интервал" />
    <serviceTask id="ST_ValidateInput" name="Валидация параметров брони" />
    <serviceTask id="ST_CheckAvailability" name="Проверка доступности слота" />
    <exclusiveGateway id="GX_Available" name="Слот доступен?" />
    <endEvent id="End_NoSlots" name="Нет доступных слотов" />
    <userTask id="UT_Confirm" name="Подтвердить бронирование" />
    <serviceTask id="ST_CreateBooking" name="Создать бронь в БД" />
    <serviceTask id="ST_Notify" name="Уведомить участников/ресурс" />
    <endEvent id="End_Success" name="Бронирование создано" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectResource" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectResource" targetRef="UT_SelectDateTime" />
    <sequenceFlow id="F6" sourceRef="UT_SelectDateTime" targetRef="ST_ValidateInput" />
    <sequenceFlow id="F7" sourceRef="ST_ValidateInput" targetRef="ST_CheckAvailability" />
    <sequenceFlow id="F8" sourceRef="ST_CheckAvailability" targetRef="GX_Available" />
    <sequenceFlow id="F9_yes" name="да" sourceRef="GX_Available" targetRef="UT_Confirm" />
    <sequenceFlow id="F9_no" name="нет" sourceRef="GX_Available" targetRef="End_NoSlots" />
    <sequenceFlow id="F10" sourceRef="UT_Confirm" targetRef="ST_CreateBooking" />
    <sequenceFlow id="F11" sourceRef="ST_CreateBooking" targetRef="ST_Notify" />
    <sequenceFlow id="F12" sourceRef="ST_Notify" targetRef="End_Success" />
  </process>
  <bpmndi:BPMNDiagram id="DI_Booking_v1">
    <bpmndi:BPMNPlane id="Plane_Booking_v1" bpmnElement="process_booking">
      <bpmndi:BPMNShape id="DI_Start" bpmnElement="Start">
        <omgdc:Bounds x="120" y="460" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="119" y="496" width="39" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_UT_OpenModule" bpmnElement="UT_OpenModule">
        <omgdc:Bounds x="190" y="448" width="300" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_ST_CheckPerms" bpmnElement="ST_CheckPerms">
        <omgdc:Bounds x="520" y="448" width="240" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_End_NoAccess" bpmnElement="End_NoAccess">
