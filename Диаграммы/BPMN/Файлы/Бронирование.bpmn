      <bpmndi:BPMNShape id="DI_ST_CheckAvailability" bpmnElement="ST_CheckAvailability">
        <omgdc:Bounds x="1880" y="260" width="260" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_GX_Available" bpmnElement="GX_Available" isMarkerVisible="true">
        <omgdc:Bounds x="2375" y="265" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2435" y="283" width="82" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_End_NoSlots" bpmnElement="End_NoSlots">
        <omgdc:Bounds x="2582" y="122" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2561" y="84.5" width="77" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_UT_Confirm" bpmnElement="UT_Confirm">
        <omgdc:Bounds x="2500" y="410" width="240" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_ST_CreateBooking" bpmnElement="ST_CreateBooking">
        <omgdc:Bounds x="2780" y="410" width="260" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_ST_Notify" bpmnElement="ST_Notify">
        <omgdc:Bounds x="3100" y="410" width="260" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_End_Success" bpmnElement="End_Success">
        <omgdc:Bounds x="3482" y="292" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="3463" y="328" width="75" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="DE_F1" bpmnElement="F1">
        <omgdi:waypoint x="156" y="478" />
        <omgdi:waypoint x="190" y="478" />
