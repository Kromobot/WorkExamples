      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_UT_SelectResource" bpmnElement="UT_SelectResource">
        <omgdc:Bounds x="940" y="260" width="300" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_GX_Perms" bpmnElement="GX_Perms" isMarkerVisible="true">
        <omgdc:Bounds x="815" y="453" width="50" height="50" />
