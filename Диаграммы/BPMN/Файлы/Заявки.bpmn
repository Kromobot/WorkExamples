<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_CreateMaintenanceRequest_v1" targetNamespace="http://example.com/bpmn/requests/maintenance" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_create_maintenance_request" name="Создание заявки на обслуживание объектов" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_SelectObject" name="Выбрать объект на плане" />
    <userTask id="UT_ClickCreate" name="Нажать «Создать заявку»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <serviceTask id="ST_OpenForm" name="Открыть форму заявки" />
    <userTask id="UT_FillForm" name="Заполнить форму (тип работ, описание, срочность, файлы)" />
    <serviceTask id="ST_Validate" name="Валидация данных формы" />
    <exclusiveGateway id="GX_Valid" name="Данные корректны?" />
    <exclusiveGateway id="GX_Route" name="Внутренняя заявка?" />
    <serviceTask id="ST_SendInternal" name="Отправить во внутренний сервис">
      <outgoing>Flow_0idjm0v</outgoing>
    </serviceTask>
    <serviceTask id="ST_SendExternal" name="Отправить во внешний сервис">
      <outgoing>Flow_0j94n44</outgoing>
    </serviceTask>
    <serviceTask id="ST_UpdateAndNotify" name="Сохранить, обновить список и уведомить">
      <incoming>Flow_0j94n44</incoming>
      <incoming>Flow_0idjm0v</incoming>
    </serviceTask>
    <endEvent id="End_Success" name="Заявка создана" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_SelectObject" />
    <sequenceFlow id="F2" sourceRef="UT_SelectObject" targetRef="UT_ClickCreate" />
    <sequenceFlow id="F3" sourceRef="UT_ClickCreate" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F4" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F5_yes" name="да" sourceRef="GX_Perms" targetRef="ST_OpenForm" />
    <sequenceFlow id="F5_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F6" sourceRef="ST_OpenForm" targetRef="UT_FillForm" />
    <sequenceFlow id="F7" sourceRef="UT_FillForm" targetRef="ST_Validate" />
    <sequenceFlow id="F8" sourceRef="ST_Validate" targetRef="GX_Valid" />
    <sequenceFlow id="F9_fix" name="нет" sourceRef="GX_Valid" targetRef="UT_FillForm" />
    <sequenceFlow id="F9_ok" name="да" sourceRef="GX_Valid" targetRef="GX_Route" />
    <sequenceFlow id="F10_int" name="да" sourceRef="GX_Route" targetRef="ST_SendInternal" />
    <sequenceFlow id="F10_ext" name="нет" sourceRef="GX_Route" targetRef="ST_SendExternal" />
    <sequenceFlow id="F13" sourceRef="ST_UpdateAndNotify" targetRef="End_Success" />
    <sequenceFlow id="Flow_0j94n44" sourceRef="ST_SendExternal" targetRef="ST_UpdateAndNotify" />
    <sequenceFlow id="Flow_0idjm0v" sourceRef="ST_SendInternal" targetRef="ST_UpdateAndNotify" />
  </process>
