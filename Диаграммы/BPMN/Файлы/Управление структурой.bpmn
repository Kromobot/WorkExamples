<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ProjectStructure" targetNamespace="http://example.com/bpmn/project-structure" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_project_structure" name="Управление проектной структурой" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль структуры" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectAction" name="Выбрать действие (создать/редактировать/удалить)" />
    <exclusiveGateway id="GX_Action_1" name="Создать?" />
    <userTask id="UT_Create" name="Создать элемент (офис/этаж/слой/зону/объект)" />
    <serviceTask id="ST_SaveCreate" name="Сохранить новый элемент" />
    <exclusiveGateway id="GX_Action_2" name="Редактировать или удалить?" />
    <userTask id="UT_Edit" name="Редактировать выбранный элемент" />
    <serviceTask id="ST_SaveEdit" name="Сохранить изменения" />
    <userTask id="UT_Delete" name="Удалить элемент" />
    <serviceTask id="ST_Delete" name="Удалить из структуры" />
    <serviceTask id="ST_Refresh" name="Обновить представление структуры" />
    <endEvent id="End_Success" name="Структура обновлена" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectAction" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectAction" targetRef="GX_Action_1" />
    <sequenceFlow id="F6_create" name="да" sourceRef="GX_Action_1" targetRef="UT_Create" />
    <sequenceFlow id="F6_else" name="нет" sourceRef="GX_Action_1" targetRef="GX_Action_2" />
    <sequenceFlow id="F7" sourceRef="UT_Create" targetRef="ST_SaveCreate" />
    <sequenceFlow id="F8" sourceRef="ST_SaveCreate" targetRef="ST_Refresh" />
    <sequenceFlow id="F9_edit" name="редактировать" sourceRef="GX_Action_2" targetRef="UT_Edit" />
    <sequenceFlow id="F9_delete" name="удалить" sourceRef="GX_Action_2" targetRef="UT_Delete" />
    <sequenceFlow id="F10" sourceRef="UT_Edit" targetRef="ST_SaveEdit" />
    <sequenceFlow id="F11" sourceRef="ST_SaveEdit" targetRef="ST_Refresh" />
    <sequenceFlow id="F12" sourceRef="UT_Delete" targetRef="ST_Delete" />
    <sequenceFlow id="F13" sourceRef="ST_Delete" targetRef="ST_Refresh" />
    <sequenceFlow id="F14" sourceRef="ST_Refresh" targetRef="End_Success" />
  </process>
  <bpmndi:BPMNDiagram id="DI_ProjectStructure">
    <bpmndi:BPMNPlane id="Plane_ProjectStructure" bpmnElement="process_project_structure">
      <bpmndi:BPMNShape id="DI_Start" bpmnElement="Start">
        <omgdc:Bounds x="120" y="210" width="36" height="36" />
        <bpmndi:BPMNLabel>
