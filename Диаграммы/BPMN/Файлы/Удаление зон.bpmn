      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_ST_RenderUpdate" bpmnElement="ST_RenderUpdate">
        <omgdc:Bounds x="2490" y="60" width="240" height="60" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="DI_End_Success" bpmnElement="End_Success">
        <omgdc:Bounds x="2752" y="72" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="2735" y="108" width="71" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="DE_F1" bpmnElement="F1">
        <omgdi:waypoint x="196" y="178" />
        <omgdi:waypoint x="230" y="178" />
