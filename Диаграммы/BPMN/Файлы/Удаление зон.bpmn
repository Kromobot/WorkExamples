<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_DeleteZone_v1_UpDown" targetNamespace="http://example.com/bpmn/zones/delete" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_delete_zone_v1" name="Удаление зоны (XOR: выходы только вверх/вниз)" isExecutable="false">
    <startEvent id="Start_DeleteZone" name="Начало" />
    <userTask id="UT_OpenZones" name="Открыть редактор зон" />
    <userTask id="UT_SelectFloor" name="Выбрать этаж" />
    <userTask id="UT_SelectLayer" name="Выбрать слой" />
    <userTask id="UT_SelectZone" name="Выбрать зону" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Прав достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_ClickDelete" name="Нажать «Удалить зону»" />
    <userTask id="UT_Confirm" name="Подтвердить удаление" />
    <serviceTask id="ST_DeleteFromDB" name="Удаление зоны из БД" />
    <serviceTask id="ST_RenderUpdate" name="Обновление отображения плана" />
    <endEvent id="End_Success" name="Зона удалена" />
    <sequenceFlow id="F1" sourceRef="Start_DeleteZone" targetRef="UT_OpenZones" />
    <sequenceFlow id="F2" sourceRef="UT_OpenZones" targetRef="UT_SelectFloor" />
    <sequenceFlow id="F3" sourceRef="UT_SelectFloor" targetRef="UT_SelectLayer" />
    <sequenceFlow id="F4" sourceRef="UT_SelectLayer" targetRef="UT_SelectZone" />
    <sequenceFlow id="F5" sourceRef="UT_SelectZone" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F6" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F7_yes" name="да" sourceRef="GX_Perms" targetRef="UT_ClickDelete" />
    <sequenceFlow id="F7_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F8" sourceRef="UT_ClickDelete" targetRef="UT_Confirm" />
    <sequenceFlow id="F9" sourceRef="UT_Confirm" targetRef="ST_DeleteFromDB" />
    <sequenceFlow id="F10" sourceRef="ST_DeleteFromDB" targetRef="ST_RenderUpdate" />
    <sequenceFlow id="F11" sourceRef="ST_RenderUpdate" targetRef="End_Success" />
  </process>
  <bpmndi:BPMNDiagram id="DI_DeleteZone_v1">
    <bpmndi:BPMNPlane id="Plane_DeleteZone_v1" bpmnElement="process_delete_zone_v1">
      <bpmndi:BPMNShape id="DI_Start_DeleteZone" bpmnElement="Start_DeleteZone">
        <omgdc:Bounds x="160" y="160" width="36" height="36" />
