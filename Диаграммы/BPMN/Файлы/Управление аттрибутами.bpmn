<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ManageAttributes_v1" targetNamespace="http://example.com/bpmn/attributes/manage" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_manage_attributes" name="Управление атрибутами" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль «Атрибуты»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectAction" name="Выбрать действие" />
    <exclusiveGateway id="GX_Action_1" name="Создать?" />
    <userTask id="UT_SelectScope" name="Выбрать область (объект/зона)" />
    <userTask id="UT_SelectTarget" name="Выбрать конкретный объект/зону" />
    <userTask id="UT_DefineAttribute" name="Задать атрибут (имя/тип/обяз./справочник)" />
    <serviceTask id="ST_SaveCreate" name="Сохранить новый атрибут" />
    <exclusiveGateway id="GX_Action_2" name="Редактировать?" />
    <userTask id="UT_SelectAttr_Edit" name="Выбрать атрибут" />
    <userTask id="UT_EditAttr" name="Изменить свойства/значения по умолчанию" />
    <serviceTask id="ST_SaveEdit" name="Сохранить изменения атрибута" />
    <exclusiveGateway id="GX_Action_3" name="Удалить?" />
    <userTask id="UT_SelectAttr_Del" name="Выбрать атрибут" />
    <userTask id="UT_ConfirmDelete" name="Подтвердить удаление" />
    <serviceTask id="ST_DoDelete" name="Удалить атрибут из БД" />
    <serviceTask id="ST_Refresh" name="Обновить отображение/индексы поиска" />
    <endEvent id="End_Success" name="Изменения применены" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectAction" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectAction" targetRef="GX_Action_1" />
    <sequenceFlow id="F6_create" name="да" sourceRef="GX_Action_1" targetRef="UT_SelectScope" />
    <sequenceFlow id="F6_else" name="нет" sourceRef="GX_Action_1" targetRef="GX_Action_2" />
    <sequenceFlow id="F7" sourceRef="UT_SelectScope" targetRef="UT_SelectTarget" />
    <sequenceFlow id="F8" sourceRef="UT_SelectTarget" targetRef="UT_DefineAttribute" />
    <sequenceFlow id="F9" sourceRef="UT_DefineAttribute" targetRef="ST_SaveCreate" />
    <sequenceFlow id="F10" sourceRef="ST_SaveCreate" targetRef="ST_Refresh" />
    <sequenceFlow id="F11_edit" name="да" sourceRef="GX_Action_2" targetRef="UT_SelectAttr_Edit" />
    <sequenceFlow id="F11_else" name="нет" sourceRef="GX_Action_2" targetRef="GX_Action_3" />
    <sequenceFlow id="F12" sourceRef="UT_SelectAttr_Edit" targetRef="UT_EditAttr" />
    <sequenceFlow id="F13" sourceRef="UT_EditAttr" targetRef="ST_SaveEdit" />
    <sequenceFlow id="F14" sourceRef="ST_SaveEdit" targetRef="ST_Refresh" />
    <sequenceFlow id="F15_delete" name="да" sourceRef="GX_Action_3" targetRef="UT_SelectAttr_Del" />
    <sequenceFlow id="F15_else" name="нет" sourceRef="GX_Action_3" targetRef="ST_Refresh" />
    <sequenceFlow id="F16" sourceRef="UT_SelectAttr_Del" targetRef="UT_ConfirmDelete" />
    <sequenceFlow id="F17" sourceRef="UT_ConfirmDelete" targetRef="ST_DoDelete" />
    <sequenceFlow id="F18" sourceRef="ST_DoDelete" targetRef="ST_Refresh" />
    <sequenceFlow id="F19" sourceRef="ST_Refresh" targetRef="End_Success" />
  </process>
