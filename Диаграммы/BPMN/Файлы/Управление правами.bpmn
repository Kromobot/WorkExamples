<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_AccessRights_v1" targetNamespace="http://example.com/bpmn/access" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_access_rights" name="Управление правами" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль управления правами" />
    <serviceTask id="ST_CheckAdminPerms" name="Проверка прав администратора" />
    <exclusiveGateway id="GX_AdminPerms" name="Админ?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectUser" name="Выбрать пользователя" />
    <exclusiveGateway id="GX_UserFound" name="Пользователь найден?" />
    <endEvent id="End_NoUser" name="Ошибка: пользователь не найден" />
    <userTask id="UT_AssignRole" name="Назначить / изменить роль" />
    <serviceTask id="ST_SaveChanges" name="Сохранение прав в БД" />
    <serviceTask id="ST_Notify" name="Уведомить пользователя" />
    <endEvent id="End_Success" name="Права обновлены" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckAdminPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckAdminPerms" targetRef="GX_AdminPerms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_AdminPerms" targetRef="UT_SelectUser" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_AdminPerms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectUser" targetRef="GX_UserFound" />
    <sequenceFlow id="F6_yes" name="да" sourceRef="GX_UserFound" targetRef="UT_AssignRole" />
    <sequenceFlow id="F6_no" name="нет" sourceRef="GX_UserFound" targetRef="End_NoUser" />
    <sequenceFlow id="F7" sourceRef="UT_AssignRole" targetRef="ST_SaveChanges" />
    <sequenceFlow id="F8" sourceRef="ST_SaveChanges" targetRef="ST_Notify" />
    <sequenceFlow id="F9" sourceRef="ST_Notify" targetRef="End_Success" />
  </process>
  <bpmndi:BPMNDiagram id="DI_AccessRights_v1">
    <bpmndi:BPMNPlane id="Plane_AccessRights_v1" bpmnElement="process_access_rights">
