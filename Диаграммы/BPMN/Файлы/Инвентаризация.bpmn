<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ConductInventory_v1" targetNamespace="http://example.com/bpmn/inventory/conduct" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_conduct_inventory" name="Проведение инвентаризации" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль «Инвентаризация»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectScope" name="Выбрать офис/этаж/слой" />
    <serviceTask id="ST_ShowObjects" name="Показ списка объектов" />
    <userTask id="UT_CheckObjects" name="Осмотр и сверка объектов">
      <outgoing>Flow_0zwmr3g</outgoing>
    </userTask>
    <exclusiveGateway id="GX_ObjectExists" name="Объект найден в справочнике?">
      <incoming>Flow_0zwmr3g</incoming>
    </exclusiveGateway>
    <endEvent id="End_NoObject" name="Ошибка: объект отсутствует" />
    <userTask id="UT_UpdateObjects" name="Обновить состав и атрибуты" />
    <serviceTask id="ST_SaveChanges" name="Сохранение изменений в БД" />
    <serviceTask id="ST_Report" name="Формирование отчета" />
    <endEvent id="End_Success" name="Инвентаризация завершена" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectScope" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectScope" targetRef="ST_ShowObjects" />
    <sequenceFlow id="F6" sourceRef="ST_ShowObjects" targetRef="UT_CheckObjects" />
    <sequenceFlow id="F8_yes" name="да" sourceRef="GX_ObjectExists" targetRef="UT_UpdateObjects" />
    <sequenceFlow id="F8_no" name="нет" sourceRef="GX_ObjectExists" targetRef="End_NoObject" />
    <sequenceFlow id="F9" sourceRef="UT_UpdateObjects" targetRef="ST_SaveChanges" />
    <sequenceFlow id="F10" sourceRef="ST_SaveChanges" targetRef="ST_Report" />
    <sequenceFlow id="F11" sourceRef="ST_Report" targetRef="End_Success" />
    <sequenceFlow id="Flow_0zwmr3g" sourceRef="UT_CheckObjects" targetRef="GX_ObjectExists" />
  </process>
