<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Defs_ManageZones_v1" targetNamespace="http://example.com/bpmn/zones/manage" exporter="Camunda Modeler" exporterVersion="5.38.0">
  <process id="process_manage_zones" name="Управление зонами" isExecutable="false">
    <startEvent id="Start" name="Начало" />
    <userTask id="UT_OpenModule" name="Открыть модуль «Управление зонами»" />
    <serviceTask id="ST_CheckPerms" name="Проверка прав доступа" />
    <exclusiveGateway id="GX_Perms" name="Права достаточно?" />
    <endEvent id="End_NoAccess" name="Доступ запрещён" />
    <userTask id="UT_SelectAction" name="Выбрать действие" />
    <exclusiveGateway id="GX_Action_1" name="Создать?" />
    <userTask id="UT_Create" name="Создать зону" />
    <serviceTask id="ST_SaveCreate" name="Сохранить новую зону" />
    <exclusiveGateway id="GX_Action_2" name="Редактировать?" />
    <userTask id="UT_Edit" name="Редактировать зону" />
    <serviceTask id="ST_SaveEdit" name="Сохранить изменения зоны" />
    <exclusiveGateway id="GX_Action_3" name="Удалить?" />
    <userTask id="UT_Delete" name="Удалить зону (подтвердить)" />
    <serviceTask id="ST_DoDelete" name="Удалить зону и отвязать объекты" />
    <exclusiveGateway id="GX_Action_4" name="Изменить цвет?" />
    <userTask id="UT_ChangeColor" name="Изменить цвет зоны" />
    <serviceTask id="ST_SaveColor" name="Применить цвет к однотипным зонам" />
    <userTask id="UT_SetAllowed" name="Определить набор объектов для зоны" />
    <serviceTask id="ST_SaveAllowed" name="Сохранить ограничения по объектам" />
    <serviceTask id="ST_RefreshMap" name="Обновить карту/отображение" />
    <endEvent id="End_Success" name="Изменения применены" />
    <sequenceFlow id="F1" sourceRef="Start" targetRef="UT_OpenModule" />
    <sequenceFlow id="F2" sourceRef="UT_OpenModule" targetRef="ST_CheckPerms" />
    <sequenceFlow id="F3" sourceRef="ST_CheckPerms" targetRef="GX_Perms" />
    <sequenceFlow id="F4_yes" name="да" sourceRef="GX_Perms" targetRef="UT_SelectAction" />
    <sequenceFlow id="F4_no" name="нет" sourceRef="GX_Perms" targetRef="End_NoAccess" />
    <sequenceFlow id="F5" sourceRef="UT_SelectAction" targetRef="GX_Action_1" />
    <sequenceFlow id="F6_create" name="да" sourceRef="GX_Action_1" targetRef="UT_Create" />
    <sequenceFlow id="F6_else" name="нет" sourceRef="GX_Action_1" targetRef="GX_Action_2" />
    <sequenceFlow id="F7" sourceRef="UT_Create" targetRef="ST_SaveCreate" />
    <sequenceFlow id="F8" sourceRef="ST_SaveCreate" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F9_edit" name="да" sourceRef="GX_Action_2" targetRef="UT_Edit" />
    <sequenceFlow id="F9_else" name="нет" sourceRef="GX_Action_2" targetRef="GX_Action_3" />
    <sequenceFlow id="F10" sourceRef="UT_Edit" targetRef="ST_SaveEdit" />
    <sequenceFlow id="F11" sourceRef="ST_SaveEdit" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F12_delete" name="да" sourceRef="GX_Action_3" targetRef="UT_Delete" />
    <sequenceFlow id="F12_else" name="нет" sourceRef="GX_Action_3" targetRef="GX_Action_4" />
    <sequenceFlow id="F13" sourceRef="UT_Delete" targetRef="ST_DoDelete" />
    <sequenceFlow id="F14" sourceRef="ST_DoDelete" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F15_color" name="да" sourceRef="GX_Action_4" targetRef="UT_ChangeColor" />
    <sequenceFlow id="F15_else" name="нет" sourceRef="GX_Action_4" targetRef="UT_SetAllowed" />
    <sequenceFlow id="F16" sourceRef="UT_ChangeColor" targetRef="ST_SaveColor" />
    <sequenceFlow id="F17" sourceRef="ST_SaveColor" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F18" sourceRef="UT_SetAllowed" targetRef="ST_SaveAllowed" />
    <sequenceFlow id="F19" sourceRef="ST_SaveAllowed" targetRef="ST_RefreshMap" />
    <sequenceFlow id="F20" sourceRef="ST_RefreshMap" targetRef="End_Success" />
  </process>
